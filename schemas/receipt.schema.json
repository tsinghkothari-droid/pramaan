{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tsinghkothari-droid/pramaan/main/schemas/receipt.schema.json",
  "title": "Pramaan Stage Receipt v0.1",
  "description": "A versioned receipt describing one Pramaan stage, its evidence, and its mitigated/residual/not-applicable risks. It is audit evidence, not a correctness proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage",
    "status",
    "tool",
    "started_at",
    "ended_at",
    "inputs",
    "outputs",
    "artifacts",
    "summary",
    "limitations",
    "mitigated_risks",
    "residual_risks",
    "not_applicable_risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.receipt.v1"
    },
    "stage": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$"
    },
    "status": {
      "$ref": "#/$defs/stage_status"
    },
    "tool": {
      "$ref": "#/$defs/tool_identity"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "exit_code": {
      "type": ["integer", "null"]
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_ref"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/output_ref"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "summary": {
      "$ref": "#/$defs/receipt_summary"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mitigated_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "residual_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "not_applicable_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "agent_author": {
      "$ref": "#/$defs/agent_attribution"
    },
    "reviewer_override": {
      "$ref": "#/$defs/reviewer_override"
    },
    "multi_agent_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenance_entry"
      }
    },
    "plugin_identity": {
      "$ref": "#/$defs/plugin_identity"
    },
    "plugin_permissions": {
      "$ref": "#/$defs/plugin_permissions"
    },
    "evidence_sensitivity": {
      "$ref": "#/$defs/evidence_sensitivity"
    },
    "redaction_manifest": {
      "$ref": "#/$defs/redaction_manifest"
    },
    "policy_decision": {
      "$ref": "#/$defs/policy_decision"
    },
    "stage_budget": {
      "$ref": "#/$defs/stage_budget"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "stage_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped", "not_applicable", "timed_out", "error"]
    },
    "tool_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "input_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        },
        "digest": {
          "type": ["string", "null"]
        }
      }
    },
    "output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "digest": {
          "type": ["string", "null"]
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "media_type": {
          "type": ["string", "null"]
        },
        "digest": {
          "type": ["string", "null"]
        }
      }
    },
    "receipt_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "details"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk_id_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^R-[0-9]{3}$"
      }
    },
    "agent_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "execution_mode", "source", "confidence"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "model_family": { "type": ["string", "null"] },
        "model_version": { "type": ["string", "null"] },
        "execution_mode": { "type": "string", "minLength": 1 },
        "prompt_context_hash": { "type": ["string", "null"] },
        "commit_provenance": { "type": ["string", "null"] },
        "source": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        }
      }
    },
    "reviewer_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "accepted_risk_ids",
        "reviewer_identity_source",
        "timestamp",
        "reason",
        "update_calibration"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["approved_despite_risk", "rejected", "needs_follow_up"]
        },
        "accepted_risk_ids": { "$ref": "#/$defs/risk_id_array" },
        "reviewer_identity_source": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "linked_outcome": { "type": ["string", "null"] },
        "update_calibration": { "type": "boolean" }
      }
    },
    "provenance_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "agent"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "agent": { "$ref": "#/$defs/agent_attribution" },
        "commit_sha": { "type": ["string", "null"], "pattern": "^[a-fA-F0-9]{7,64}$" },
        "handoff_id": { "type": ["string", "null"] }
      }
    },
    "plugin_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "provenance", "sandbox_boundary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "signature": { "type": ["string", "null"] },
        "sandbox_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "plugin_permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_emit_receipts",
        "may_emit_artifacts",
        "may_read_previous_receipts",
        "may_modify_previous_receipts",
        "may_modify_manifest"
      ],
      "properties": {
        "may_emit_receipts": { "type": "boolean" },
        "may_emit_artifacts": { "type": "boolean" },
        "may_read_previous_receipts": { "type": "boolean" },
        "may_modify_previous_receipts": { "type": "boolean" },
        "may_modify_manifest": { "type": "boolean" }
      }
    },
    "evidence_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "secret_derived", "redacted"]
    },
    "redaction_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "redacted_fields", "hashed_fields", "policy"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "redacted_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hashed_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policy": { "type": "string", "minLength": 1 }
      }
    },
    "policy_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "policy_id", "hard_failures", "warnings", "waived"],
      "properties": {
        "decision": { "type": "string", "minLength": 1 },
        "policy_id": { "type": "string", "minLength": 1 },
        "hard_failures": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "waived": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stage_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ms", "max_ms", "consumed_ms", "exhausted", "partial_evidence"],
      "properties": {
        "target_ms": { "type": "integer", "minimum": 0 },
        "max_ms": { "type": "integer", "minimum": 0 },
        "consumed_ms": { "type": "integer", "minimum": 0 },
        "exhausted": { "type": "boolean" },
        "timeout_reason": { "type": ["string", "null"] },
        "partial_evidence": { "type": "boolean" }
      }
    }
  }
}
