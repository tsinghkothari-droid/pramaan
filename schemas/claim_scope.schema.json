{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pramaan.dev/v1/claim_scope.schema.json",
  "title": "Pramaan Claim Scope",
  "description": "Runtime claim-scope shape emitted by the Pramaan Rust CLI.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_refs",
    "expected_behavior",
    "out_of_scope_behavior",
    "touched_public_apis",
    "extraction_method",
    "confidence",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.claim_scope.v1"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "reference"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expected_behavior": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope_behavior": {
      "type": "array",
      "items": { "type": "string" }
    },
    "touched_public_apis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extraction_method": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^R-[0-9]{3}$"
      }
    }
  }
}
