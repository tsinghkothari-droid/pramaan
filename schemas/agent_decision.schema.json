{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pramaan.dev/v1/agent_decision.schema.json",
  "title": "Pramaan Agent Completion Gate Decision",
  "description": "A deterministic pass/warn/block response for coding agents. This is a completion gate over Pramaan evidence, not agent self-certification or correctness proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "reason",
    "bundle_path",
    "blocking_stages",
    "warnings",
    "required_actions",
    "agent_message",
    "human_override_allowed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.agent_decision.v1"
    },
    "decision": {
      "type": "string",
      "enum": ["pass", "warn", "block"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "blocking_stages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "agent_message": {
      "type": "string",
      "minLength": 1
    },
    "human_override_allowed": {
      "type": "boolean"
    }
  }
}
