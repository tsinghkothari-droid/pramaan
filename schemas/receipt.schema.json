{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pramaan.dev/v1/receipt.schema.json",
  "title": "Pramaan Stage Receipt",
  "description": "A versioned receipt describing what one Pramaan stage ran, what evidence it produced, and which risks it mitigated or left open. It is not a correctness proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "stage",
    "status",
    "tool",
    "timing",
    "inputs",
    "outputs",
    "artifacts",
    "summary",
    "mitigated_risks",
    "residual_risks",
    "not_applicable_risks",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^rcpt_[A-Za-z0-9._-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9._-]+$"
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "claim_scope",
            "sandbox",
            "static",
            "oracle_integrity",
            "mutation",
            "differential_fuzz",
            "bundle",
            "smoke",
            "other"
          ]
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      }
    },
    "status": {
      "$ref": "#/$defs/stage_status"
    },
    "exit_code": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "tool": {
      "$ref": "#/$defs/tool_identity"
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "ended_at", "duration_ms"],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "timeout_ms": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "result", "details"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": ["number", "integer", "string", "boolean", "null"]
          }
        }
      }
    },
    "mitigated_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "residual_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "not_applicable_risks": {
      "$ref": "#/$defs/risk_id_array"
    },
    "agent_author": {
      "$ref": "#/$defs/agent_attribution"
    },
    "reviewer_override": {
      "$ref": "#/$defs/reviewer_override"
    },
    "multi_agent_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenance_entry"
      }
    },
    "plugin_identity": {
      "$ref": "#/$defs/plugin_identity"
    },
    "plugin_permissions": {
      "$ref": "#/$defs/plugin_permissions"
    },
    "evidence_sensitivity": {
      "$ref": "#/$defs/evidence_sensitivity"
    },
    "redaction_manifest": {
      "$ref": "#/$defs/redaction_manifest"
    },
    "policy_decision": {
      "$ref": "#/$defs/policy_decision"
    },
    "stage_budget": {
      "$ref": "#/$defs/stage_budget"
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/limitation"
      }
    },
    "claim_scope_ref": {
      "$ref": "#/$defs/artifact_ref"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    }
  },
  "$defs": {
    "stage_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped",
        "not_applicable",
        "timed_out",
        "error"
      ]
    },
    "tool_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "vendor": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "blake3"]
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64,128}$"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "digest"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["git_ref", "diff", "file", "directory", "config", "claim_scope", "receipt", "artifact", "inline"]
        },
        "path": {
          "type": "string"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string"
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "digest", "media_type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "risk_id_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^R-[0-9]{3}$"
      }
    },
    "limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "description", "risk_ids"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "risk_ids": {
          "$ref": "#/$defs/risk_id_array"
        }
      }
    },
    "agent_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "execution_mode", "source", "confidence"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "model_family": { "type": "string" },
        "model_version": { "type": "string" },
        "execution_mode": { "type": "string", "minLength": 1 },
        "prompt_context_hash": { "type": "string" },
        "commit_provenance": { "type": "string" },
        "source": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        }
      }
    },
    "reviewer_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "accepted_risk_ids",
        "reviewer_identity_source",
        "timestamp",
        "reason",
        "update_calibration"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["approved_despite_risk", "rejected", "needs_follow_up"]
        },
        "accepted_risk_ids": { "$ref": "#/$defs/risk_id_array" },
        "reviewer_identity_source": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "linked_outcome": { "type": "string" },
        "update_calibration": { "type": "boolean" }
      }
    },
    "provenance_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "agent"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "agent": { "$ref": "#/$defs/agent_attribution" },
        "commit_sha": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" },
        "handoff_id": { "type": "string" }
      }
    },
    "plugin_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "provenance", "sandbox_boundary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "signature": { "type": "string" },
        "sandbox_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "plugin_permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_emit_receipts",
        "may_emit_artifacts",
        "may_read_previous_receipts",
        "may_modify_previous_receipts",
        "may_modify_manifest"
      ],
      "properties": {
        "may_emit_receipts": { "type": "boolean" },
        "may_emit_artifacts": { "type": "boolean" },
        "may_read_previous_receipts": { "type": "boolean" },
        "may_modify_previous_receipts": { "type": "boolean" },
        "may_modify_manifest": { "type": "boolean" }
      }
    },
    "evidence_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "secret_derived", "redacted"]
    },
    "redaction_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "redacted_fields", "hashed_fields", "policy"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "redacted_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hashed_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policy": { "type": "string", "minLength": 1 }
      }
    },
    "policy_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "policy_id", "hard_failures", "warnings", "waived"],
      "properties": {
        "decision": { "type": "string", "minLength": 1 },
        "policy_id": { "type": "string", "minLength": 1 },
        "hard_failures": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "waived": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stage_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ms", "max_ms", "consumed_ms", "exhausted", "partial_evidence"],
      "properties": {
        "target_ms": { "type": "integer", "minimum": 0 },
        "max_ms": { "type": "integer", "minimum": 0 },
        "consumed_ms": { "type": "integer", "minimum": 0 },
        "exhausted": { "type": "boolean" },
        "timeout_reason": { "type": "string" },
        "partial_evidence": { "type": "boolean" }
      }
    }
  }
}
