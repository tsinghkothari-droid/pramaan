{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pramaan.dev/v1/vsa.schema.json",
  "title": "Pramaan Verification Summary Attestation",
  "description": "A SLSA VSA-style local/offline summary of the Pramaan bundle decision. It is evidence, not a correctness proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "predicate_type",
    "subject",
    "verifier",
    "time_verified",
    "policy",
    "verification_result",
    "manifest_digest",
    "verified_levels",
    "dependency_levels",
    "resource_uri",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.vsa.v1"
    },
    "predicate_type": {
      "type": "string",
      "const": "https://slsa.dev/verification_summary/v1"
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/subject"
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "time_verified": {
      "type": "string",
      "format": "date-time"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uri"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verification_result": {
      "type": "string",
      "enum": ["PASSED", "WARNING", "FAILED"]
    },
    "manifest_digest": {
      "$ref": "#/$defs/digest"
    },
    "confidence_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": {
          "type": "string",
          "const": "confidence.json"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "verified_levels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependency_levels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resource_uri": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "value": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "required": ["sha256"],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      }
    }
  }
}
