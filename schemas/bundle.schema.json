{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pramaan.dev/v1/bundle.schema.json",
  "title": "Pramaan Proof Bundle Manifest",
  "description": "A manifest that references Pramaan receipts and artifacts by digest and summarizes evidence without reducing risk to a single score.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "run_id",
    "created_at",
    "final_status",
    "repository",
    "tool_versions",
    "stages",
    "receipts",
    "artifacts",
    "risk_summary",
    "summary",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "pramaan.bundle.v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^bundle_[A-Za-z0-9._-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "final_status": {
      "type": "string",
      "enum": ["passed", "failed", "inconclusive", "error"]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "base_ref", "head_ref"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "base_ref": {
          "type": "string",
          "minLength": 1
        },
        "head_ref": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{7,64}$"
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{7,64}$"
        }
      }
    },
    "tool_versions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool_identity"
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage_manifest"
      }
    },
    "receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manifest_ref"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/manifest_ref"
      }
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mitigated",
        "residual",
        "skipped",
        "not_applicable"
      ],
      "properties": {
        "mitigated": {
          "$ref": "#/$defs/risk_id_array"
        },
        "residual": {
          "$ref": "#/$defs/risk_id_array"
        },
        "skipped": {
          "$ref": "#/$defs/risk_id_array"
        },
        "not_applicable": {
          "$ref": "#/$defs/risk_id_array"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidence", "residual_risk_note"],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "residual_risk_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_digest"],
      "properties": {
        "manifest_digest": {
          "$ref": "#/$defs/digest"
        },
        "signing": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["mode", "status"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "local_dev", "sigstore_keyless", "external"]
            },
            "status": {
              "type": "string",
              "enum": ["unsigned", "signable", "signed", "verified", "unverified"]
            },
            "dev_mode": {
              "type": "boolean",
              "description": "True when signing/signable metadata was produced outside CI-backed provenance."
            },
            "signable_digest": {
              "$ref": "#/$defs/digest"
            },
            "note": {
              "type": "string",
              "minLength": 1
            },
            "signature_path": {
              "type": "string"
            },
            "certificate_path": {
              "type": "string"
            }
          }
        },
        "artifact_attestation": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["provider", "status"],
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["github_actions", "sigstore", "slsa", "none", "other"]
            },
            "status": {
              "type": "string",
              "enum": ["not_requested", "requested", "present", "verified", "unverified"]
            },
            "attestation_path": {
              "type": "string"
            },
            "issuer": {
              "type": "string"
            },
            "subject": {
              "type": "string"
            },
            "workflow": {
              "type": "string"
            },
            "repository": {
              "type": "string"
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{7,64}$"
            },
            "transparency_mode": {
              "type": "string",
              "enum": ["public_rekor", "github_private", "none", "unknown", "other"]
            }
          }
        }
      }
    },
    "agent_attribution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent_attribution"
      }
    },
    "reviewer_overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewer_override"
      }
    },
    "multi_agent_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenance_entry"
      }
    },
    "plugin_identities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin_identity"
      }
    },
    "redaction_manifest": {
      "$ref": "#/$defs/redaction_manifest"
    },
    "policy_decision": {
      "$ref": "#/$defs/policy_decision"
    },
    "stage_budgets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_budget"
      }
    }
  },
  "$defs": {
    "tool_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "type": "string"
        }
      }
    },
    "manifest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "digest", "media_type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "stage_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "receipt_path",
        "tool",
        "mitigated_risks",
        "residual_risks",
        "not_applicable_risks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_:-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "not_applicable",
            "timed_out",
            "error"
          ]
        },
        "receipt_path": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "$ref": "#/$defs/tool_identity"
        },
        "mitigated_risks": {
          "$ref": "#/$defs/risk_id_array"
        },
        "residual_risks": {
          "$ref": "#/$defs/risk_id_array"
        },
        "not_applicable_risks": {
          "$ref": "#/$defs/risk_id_array"
        },
        "seeds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "corpus_hashes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "plugin_identity": {
          "$ref": "#/$defs/plugin_identity"
        },
        "policy_decision": {
          "$ref": "#/$defs/policy_decision"
        },
        "stage_budget": {
          "$ref": "#/$defs/stage_budget"
        },
        "evidence_sensitivity": {
          "$ref": "#/$defs/evidence_sensitivity"
        }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "blake3"]
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64,128}$"
        }
      }
    },
    "risk_id_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^R-[0-9]{3}$"
      }
    },
    "agent_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "execution_mode", "source", "confidence"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "model_family": { "type": "string" },
        "model_version": { "type": "string" },
        "execution_mode": { "type": "string", "minLength": 1 },
        "prompt_context_hash": { "type": "string" },
        "commit_provenance": { "type": "string" },
        "source": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        }
      }
    },
    "reviewer_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "accepted_risk_ids",
        "reviewer_identity_source",
        "timestamp",
        "reason",
        "update_calibration"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["approved_despite_risk", "rejected", "needs_follow_up"]
        },
        "accepted_risk_ids": { "$ref": "#/$defs/risk_id_array" },
        "reviewer_identity_source": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "linked_outcome": { "type": "string" },
        "update_calibration": { "type": "boolean" }
      }
    },
    "provenance_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "agent"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "agent": { "$ref": "#/$defs/agent_attribution" },
        "commit_sha": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" },
        "handoff_id": { "type": "string" }
      }
    },
    "plugin_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "provenance", "sandbox_boundary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "signature": { "type": "string" },
        "sandbox_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "secret_derived", "redacted"]
    },
    "redaction_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "redacted_fields", "hashed_fields", "policy"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["internal-full", "reviewer-redacted", "public-demo", "summary-only"]
        },
        "redacted_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hashed_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policy": { "type": "string", "minLength": 1 }
      }
    },
    "policy_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "policy_id", "hard_failures", "warnings", "waived"],
      "properties": {
        "decision": { "type": "string", "minLength": 1 },
        "policy_id": { "type": "string", "minLength": 1 },
        "hard_failures": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "waived": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stage_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ms", "max_ms", "consumed_ms", "exhausted", "partial_evidence"],
      "properties": {
        "target_ms": { "type": "integer", "minimum": 0 },
        "max_ms": { "type": "integer", "minimum": 0 },
        "consumed_ms": { "type": "integer", "minimum": 0 },
        "exhausted": { "type": "boolean" },
        "timeout_reason": { "type": "string" },
        "partial_evidence": { "type": "boolean" }
      }
    }
  }
}
